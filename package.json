{
  "name": "pixel-pet",
  "version": "0.1.0",
  "description": "Programmatic pixel desktop pet",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit",
    "dist": "npm run build && electron-builder",
    "lint:assets": "node scripts/validate-assets.js",
    "test": "vitest run",
    "test:e2e": "npm run build && vitest run --config vitest-e2e.config.ts"
  },
  "build": {
    "appId": "com.pixelpet.app",
    "productName": "PixelPet",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "resources/**/*"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.entertainment"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.14.0",
    "electron": "^43.1.0",
    "electron-builder": "^26.0.0",
    "electron-vite": "^5.0.0",
    "playwright": "^1.61.1",
    "typescript": "^5.8.0",
    "vite": "^7.0.0",
    "vitest": "^4.1.10"
  }
}
